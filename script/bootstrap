#!/bin/bash

# Make sure everything is development forever
export NODE_ENV=development

# Load environment specific environment variables
if [ -f .env ]; then
  source .env
fi

if [ -f .env.${NODE_ENV} ]; then
  source .env.${NODE_ENV}
fi

if [ ! -d node_modules ]; then
  echo "Dependencies are not installed. Run 'npm install' or 'npm ci' first." >&2
  exit 1
fi

# Make sure project binaries are on the path
export PATH="node_modules/.bin:$PATH"
